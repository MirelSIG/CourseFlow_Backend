# ==========================================
# Variables de Entorno - CourseFlow
# Copiar a .env y completar con valores reales.
# Render carga estas variables desde el dashboard o render.yaml,
# no es necesario subir un archivo .env al repositorio.
# ==========================================

# ==========================================
# BASE DE DATOS
# ==========================================
# Preferido: DATABASE_URL
DATABASE_URL=postgresql+psycopg2://courseflow_user:courseflow_pass@postgres:5432/courseflow

# Alternativa: si no usas DATABASE_URL, el sistema arma la conexión desde DB_*.
DB_HOST=postgres
DB_PORT=5432
DB_USER=courseflow_user
DB_PASSWORD=courseflow_pass
DB_NAME=courseflow

# ==========================================
# AUTENTICACIÓN
# ==========================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# BOOTSTRAP SUPERADMIN
# ==========================================
SUPERADMIN_EMAIL=admin@courseflow.dev
SUPERADMIN_PASSWORD=admin123

# ==========================================
# CORS Y ENTORNO
# ==========================================
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development
DEBUG=True
