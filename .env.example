# ==========================================
# Variables de Entorno - CourseFlow
# Copiar a .env y completar con valores reales
# ==========================================

# ==========================================
# DOCKER & POSTGRESQL
# ==========================================
POSTGRES_USER=courseflow_user
POSTGRES_PASSWORD=courseflow_pass
POSTGRES_DB=courseflow
POSTGRES_PORT=5433

# ==========================================
# PGADMIN (Gestor visual de BD)
# ==========================================
PGADMIN_DEFAULT_EMAIL=admin@courseflow.dev
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5052

# ==========================================
# APLICACIÓN BACKEND
# ==========================================
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production
BACKEND_PORT=8002

# ==========================================
# BASE DE DATOS (Para conexión desde app)
# ==========================================
DB_HOST=postgres
DB_PORT=5433
DB_USER=courseflow_user
DB_PASSWORD=courseflow_pass
DB_NAME=courseflow

# ==========================================
# AUTENTICACIÓN
# ==========================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# FRONTEND
# ==========================================
VITE_API_URL=http://localhost:5000/api
VUE_APP_API_URL=http://localhost:5000/api

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==========================================
# CONFIGURACIÓN GENERAL
# ==========================================
ENVIRONMENT=development
DEBUG=True
